<meta name="viewport" content="width=device-width, initial-scale=1">
<script language="JavaScript">
  function showform(dowhat) {
    /*
    * four DIVS: browse, insert, update, delete
    * this function sets one visible the others not
    */
    if (dowhat == 'insert'){
      document.getElementById('browse').style.display = 'none';
      document.getElementById('insert').style.display = 'block';
      document.getElementById('update').style.display = 'none';
      document.getElementById('delete').style.display = 'none';
    }
    else if (dowhat == 'update'){
      document.getElementById('browse').style.display = 'none';
      document.getElementById('insert').style.display = 'none';
      document.getElementById('update').style.display = 'block';
      document.getElementById('delete').style.display = 'none';
    }
    else if (dowhat == 'delete'){
      document.getElementById('browse').style.display = 'none';
      document.getElementById('insert').style.display = 'none';
      document.getElementById('update').style.display = 'none';
      document.getElementById('delete').style.display = 'block';
    }
    else if (dowhat == 'all'){
      document.getElementById('browse').style.display = 'block';
      document.getElementById('insert').style.display = 'block';
      document.getElementById('update').style.display = 'block';
      document.getElementById('delete').style.display = 'block';
    }
    else { //by default display browse
      document.getElementById('browse').style.display = 'block';
      document.getElementById('insert').style.display = 'none';
      document.getElementById('update').style.display = 'none';
      document.getElementById('delete').style.display = 'none';
    }
  }
  function newSubject() { showform('insert'); }
  function updateSubject(pid) { showform('update'); }
  function deleteSubject(pid) { showform ('delete'); }
  function browseSubjects() { showform ('browse'); }
  function showAll() { showform ('all'); }
</script>
 <script src="https://kit.fontawesome.com/8affdb6118.js" crossorigin="anonymous"></script>
 <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js"></script>
 <body onload="browseSubjects()">
<title>Subjects</title>
<div class ="header">
<h1>Subjects</h1>
</div>
<div class="background1">
    <div id="browse">
    <center>
    <h3>Hogwart's Class Subjects</h3>
    </center>
    <table id ="subject-table" >
        {{!-- Header section --}}
        <thead>
            <tr class="th1">
                <th>Subject ID</th>
                <th>Subject Name</th>
                <th>Core Subject</th>
                <th>Class Location</th>
                <th>Instructor</th>
                <th>Delete</th>    
            </tr>
        </thead>

        {{!-- Body section --}}
        <tbody>
            {{!-- For each row, print the subjectID, subjectName, coreSubject, instructor --}}
            {{#each data}}
            <tr data-value="{{this.subjectID}}">
                <td>{{this.subjectID}}</td>
                <td>{{this.subjectName}}</td>
                <td>{{this.coreSubject}}</td>
                <td>{{this.classLocation}}</td>
                <td>{{this.instructor}}</td>
                <th><i class="fa-solid fa-trash-can" href="#" onClick="deleteSubject({{this.subjectID}})"></i></th>
            </tr>
            {{/each}}
        </tbody>
    </table>
    <center>
    <input class="bigbtn" type="button" value="Add Subject" href="#" onClick="newSubject()">
    <input class="bigbtn" type="button" value="Update Subject" href="#" onClick="updateSubject()">
    </center>
    <script type="application/javascript" src="./js/delete_subject.js"></script>
    </div><!--end of browse-->

    <!-- Adding Subjects -->
    <center>
    <div id="insert">
    <h3>Add a New Subject</h3>
    <h2>Growing Young Minds</h2>
    <p>Enter the subject information below.</p>
    <form id="add-subject-form" method="POST" action="/add-subject-form">
        <label for="input-subjectName">Subject Name: </label>
        <input type="text" name="input-subjectName" id="input-subjectName">
        <select name="input-coreSubject" id="input-coreSubject">
            <optgroup label="Core Class"></optgroup>
                <option value="1">True</option>
                <option value="0">False</option>
        </select>
        <select name="input-classLocation" id="input-classLocation">
            <option value="">Select a Location</option>
            {{#each locations}}
            <option value="{{this.locationID}}">{{this.locationName}}</option>
            {{/each}}
        </select>
        <select name="input-instructor" id="input-instructor">
            <option value="">Select an Instructor</option>
            {{#each professors}}
            <option value="{{this.employeeID}}">{{this.professorName}}</option>
            {{/each}}
        </select>
        <input type="submit">
        <input type="button" value="Cancel" href="#" onClick="browseSubjects()">
    </form>
    </div><!--end of insert-->
    </center>
    <center>
    <div id="update">
    <h3>Update A Subject</h3>
    <h2>Did Defense Against Dark Arts Loose it's Instuctor?</h2>
    <p>No worries, enter the updated Subject information below.</p>
    <form id="update-subject-form-ajax">

        <label for="update_subject_name">Subject Name </label>
        <select name="update_subject_name" id="update_subject_name">
            <option value="test">Select a Subject</option>
            {{#each data}}
            <option value="{{this.subjectID}}">{{this.subjectName}}</option>
            {{/each}}
        </select>

        <label for="update_subject_location">Location </label>
        <select name="update_subject_location" id="update_subject_location">
            <option value="0">Select a Location</option>
            {{#each locations}}
            <option value="{{this.locationID}}">{{this.locationName}}</option>
            {{/each}}
        </select>

        <label for="update_subject_instructor">Instructor </label>
            <select name="update_subject_instructor" id="update_subject_instructor">
            <option value="0">Select an Instructor</option>
            {{#each professors}}
            <option value="{{this.employeeID}}">{{this.professorName}}</option>
            {{/each}}
        </select>
        <input type="submit" onClick="browseSubjects()">
        <input type="button" value="Cancel" href="#" onClick="browseSubjects()">

    </form>
    <script type="application/javascript" src="./js/update_subject.js"></script>
    </div><!--end of update-->
    </center>
</div><!--end of background-->
</body>
